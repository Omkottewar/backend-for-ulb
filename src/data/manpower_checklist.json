          "options": [
            { "label": "Yes", "value": "yes" },
            { "label": "No", "value": "no" }
          ]
        }
      ],
      "conditionalGroups": [
        {
          "showWhen": {
            "fieldId": "gem_availability_status",
            "equals": "yes"
          },
          "fields": [
            {
              "fieldId": "gem_ok_note",
              "label": "Status",
              "type": "readonly",
              "defaultValue": "Item available in GEM — OK",
              "flagType": "success"
