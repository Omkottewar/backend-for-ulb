    {
      "order": 18,
      "title": "Mining Clearance Certificate",
      "fields": [
        {
          "type": "radio",
          "label": "Mining Clearance Certificate Available",
          "fieldId": "mining_status",
          "options": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "required": true
        }
      ],
      "sectionId": "mining_clearance",
      "conditionalGroups": [
        {
          "fields": [
            {
              "type": "date",
              "label": "Date of Certificate",
              "fieldId": "mining_certificate_date",
              "required": true
            },
            {
              "type": "number",
              "label": "Amount of Royalty (in Clearance Certificate)",
              "format": "currency",
              "fieldId": "mining_royalty_amount",
              "required": true,
              "placeholder": "Enter royalty amount in certificate"
            },
            {
              "type": "number",
              "label": "Royalty in Bill",
              "format": "currency",
              "fieldId": "mining_royalty_in_bill",
              "required": true,
              "placeholder": "Enter royalty amount in bill"
            },
            {
              "type": "number",
              "label": "TCS (2% of excess royalty)",
              "format": "currency",
              "fieldId": "tcs_amount",
              "formula": {
                "operation": "custom",
                "expression": "0.02 * max(0, mining_royalty_in_bill - mining_royalty_amount)",
                "description": "TCS = 2% × (Royalty in Bill − Royalty in Clearance Certificate). Only positive values; if bill royalty ≤ certificate royalty, TCS = 0."
              },
              "computed": true,
              "readonly": true
            }
          ],
          "showWhen": {
            "equals": "yes",
            "fieldId": "mining_status"
          }
        },
        {
          "fields": [
            {
              "type": "readonly",
              "label": "Red Flag Query",
              "fieldId": "mining_red_flag",
              "flagType": "red_flag",
              "defaultValue": "Mining clearance certificate not available"
            }
          ],
          "showWhen": {
            "equals": "no",
            "fieldId": "mining_status"
          }
        }
      ]
    },
