              "value": "applicable"
            },
            {
              "label": "Not Applicable",
              "value": "not_applicable"
            }
          ],
          "required": true
        }
      ],
      "sectionId": "additional_performance_guarantee",
      "conditionalGroups": [
        {
          "fields": [
            {
              "type": "text",
              "label": "Number of Instrument",
              "fieldId": "apg_instrument_number",
              "required": true,
              "placeholder": "Enter instrument number"
            },
            {
              "type": "text",
              "label": "Name of Bank",
              "fieldId": "apg_bank_name",
              "required": true,
              "placeholder": "Enter bank name"
            },
            {
              "type": "date",
              "label": "Date of Instrument (a)",
              "refKey": "a",
              "fieldId": "apg_instrument_date",
              "required": true
            },
            {
              "type": "date",
              "label": "Date of Expiry (b)",
              "refKey": "b",
              "fieldId": "apg_expiry_date",
              "required": true
            },
            {
              "type": "number",
              "label": "Validity (days)",
              "fieldId": "apg_validity_days",
              "formula": {
                "operands": [
                  {
                    "fieldId": "apg_expiry_date"
                  },
                  {
                    "fieldId": "apg_instrument_date"
                  }
                ],
                "operation": "date_diff_days"
              },
              "computed": true,
              "readonly": true
            }
          ],
          "showWhen": {
            "equals": "applicable",
            "fieldId": "apg_status"
          }
        }
      ]
    },
    {
      "order": 11,
      "title": "Work Dates & Completion",
      "fields": [
        {
          "type": "date",
          "label": "Date of Commencement",
          "fieldId": "date_of_commencement",
          "required": true
        },
        {
          "type": "date",
          "label": "Actual Date of Work Completion",
          "fieldId": "actual_completion_date",
          "required": true
        },
        {
          "type": "checkbox",
          "label": "Whether Date Extended?",
          "fieldId": "date_extended",
          "required": false
        }
      ],
      "sectionId": "work_dates",
      "conditionalGroups": [
        {
          "fields": [
            {
              "type": "date",
              "label": "Extended Date",
              "fieldId": "extended_date",
              "required": true
            },
            {
              "type": "text",
              "label": "Name and Authority of Extending Officer",
              "fieldId": "extending_officer_name_authority",
              "required": true,
              "placeholder": "Enter name and authority"
            },
            {
              "type": "text",
              "label": "Extension Letter Number",
              "fieldId": "extension_letter_number",
              "required": true,
              "placeholder": "Enter letter number"
            }
          ],
          "showWhen": {
            "equals": true,
            "fieldId": "date_extended"
          }
        }
      ],
      "computedDisplayFields": [
        {
          "type": "number",
          "label": "Delay (days)",
          "fieldId": "delay_days",
          "formula": {
            "operands": [
              {
                "fieldId": "actual_completion_date"
              },
              {
                "fieldId": "extended_date",
                "fallback": "actual_completion_date"
              }
            ],
            "operation": "date_diff_days",
            "description": "If extended, uses extended_date; otherwise uses estimated completion date from the agreement"
          },
          "computed": true,
          "readonly": true,
          "description": "Actual Date of Work Completion − Estimated/Extended Date of Work Completion"
        }
      ]
    },
    {
      "order": 12,
      "title": "Penalty Imposed",
      "fields": [
        {
          "type": "radio",
