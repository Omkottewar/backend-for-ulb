      "conditionalGroups": [
        {
          "fields": [
            {
              "type": "text",
              "label": "Approval Number",
              "fieldId": "financial_approval_number",
              "required": true,
              "placeholder": "Enter approval number"
            },
            {
              "type": "date",
              "label": "Date",
              "fieldId": "financial_approval_date",
