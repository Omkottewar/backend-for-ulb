    {
      "order": 8,
      "title": "SOR (Schedule of Rates)",
      "fields": [
        {
          "type": "number",
          "label": "SOR Percentage (%)",
          "fieldId": "sor_percentage",
          "required": true,
          "placeholder": "Enter SOR percentage"
        },
        {
          "type": "dropdown",
          "label": "SOR Option",
          "fieldId": "sor_option",
          "options": [
            {
              "label": "At Par",
              "value": "at_par"
            },
            {
              "label": "Above",
              "value": "above"
            },
            {
              "label": "Below",
              "value": "below"
            }
          ],
          "required": true
        },
        {
          "type": "number",
          "label": "Computed Bid Value",
          "format": "currency",
          "fieldId": "sor_computed_value",
              "formula": {
            "operation": "sor_calculation",
            "description": "At Par: tender_committee_value; Above: tender_committee_value + (tender_committee_value × sor_percentage / 100); Below: tender_committee_value − (tender_committee_value × sor_percentage / 100)",
            "baseValueField": "tender_committee_value",
            "percentageField": "sor_percentage",
            "optionField": "sor_option"
          },
          "computed": true,
          "readonly": true
        }
      ],
      "sectionId": "sor_calculation",
      "description": "Computed bid value based on Financial Approval Value and SOR percentage. At Par = Financial Approval Value; Above = Financial Approval Value + (Financial Approval Value × SOR%); Below = Financial Approval Value − (Financial Approval Value × SOR%)."
    },
    {
      "order": 9,
      "title": "EMD / TDR",
      "fields": [
        {
          "type": "radio",
          "label": "EMD/TDR Available",
          "fieldId": "emd_status",
          "options": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "required": true
        }
      ],
      "sectionId": "emd_tdr",
      "conditionalGroups": [
        {
          "fields": [
            {
              "type": "text",
              "label": "Number of Instrument",
              "fieldId": "emd_instrument_number",
              "required": true,
              "placeholder": "Enter instrument number"
            },
            {
              "type": "text",
              "label": "Name of Bank",
              "fieldId": "emd_bank_name",
              "required": true,
              "placeholder": "Enter bank name"
            },
            {
              "type": "date",
              "label": "Date of Instrument (a)",
              "refKey": "a",
              "fieldId": "emd_instrument_date",
              "required": true
            },
            {
              "type": "date",
              "label": "Date of Expiry (b)",
              "refKey": "b",
              "fieldId": "emd_expiry_date",
              "required": true
            },
            {
              "type": "number",
              "label": "Validity (days)",
              "fieldId": "emd_validity_days",
              "formula": {
                "operands": [
                  {
                    "fieldId": "emd_expiry_date"
                  },
                  {
                    "fieldId": "emd_instrument_date"
                  }
                ],
                "operation": "date_diff_days"
              },
              "computed": true,
              "readonly": true
            }
          ],
          "showWhen": {
            "equals": "yes",
            "fieldId": "emd_status"
          }
        },
        {
          "fields": [
            {
              "type": "readonly",
              "label": "Red Flag Query",
              "fieldId": "emd_red_flag",
              "flagType": "red_flag",
              "defaultValue": "EMD/TDR not available"
            }
          ],
          "showWhen": {
            "equals": "no",
            "fieldId": "emd_status"
          }
        }
      ]
    },
