{
  "formId": "advance_to_employees_checklist_v1",
  "formTitle": "Checklist for Advances to Employees",
  "version": "1.0",
  "createdAt": null,
  "updatedAt": null,
  "sections": [
    {
      "sectionId": "header",
      "title": "General Information",
      "order": 1,
      "fields": [
        {
          "fieldId": "name_of_ulb",
          "label": "Name of ULB",
          "type": "text",
          "required": true,
          "placeholder": "Enter ULB name"
        },
        {
          "fieldId": "financial_year",
          "label": "Financial Year",
          "type": "text",
          "required": true,
          "autoPopulate": true,
          "source": "system",
          "placeholder": "Auto-populated"
        },
        {
          "fieldId": "approved_by",
          "label": "Approved By",
          "type": "text",
          "required": true,
          "placeholder": "Enter approver's name"
        },
        {
          "fieldId": "note_sheet_no",
          "label": "Note Sheet No.",
          "type": "text",
          "required": true,
          "placeholder": "Enter note sheet number"
        },
        {
          "fieldId": "zone_department",
          "label": "Zone / Department",
          "type": "text",
          "required": true,
          "autoPopulate": true,
          "source": "system",
          "placeholder": "Auto-populated"
        }
      ]
    },
    {
      "sectionId": "employee_details",
      "title": "Employee Details",
      "order": 2,
      "fields": [
        {
          "fieldId": "employee_name",
          "label": "Name of Employee",
          "type": "text",
          "required": true,
          "placeholder": "Enter or search employee name",
          "source": "master_data"
        },
        {
          "fieldId": "employee_pan",
          "label": "PAN No. of Employee",
          "type": "text",
          "required": true,
          "placeholder": "Auto-filled from master data",
          "source": "master_data"
        },
        {
          "fieldId": "employee_designation",
          "label": "Designation of Employee",
          "type": "text",
          "required": true,
          "placeholder": "Auto-filled from master data",
          "source": "master_data"
        },
        {
          "fieldId": "ledger_account_no",
          "label": "Ledger A/c No.",
          "type": "text",
          "required": true,
          "placeholder": "Enter or auto-fill from master data",
          "source": "master_data"
        }
      ]
    },
    {
      "sectionId": "advance_details",
      "title": "Advance Details",
      "order": 3,
      "fields": [
        {
          "fieldId": "advance_requested",
          "label": "Advance Requested",
          "type": "number",
          "required": true,
          "placeholder": "Enter advance requested amount",
          "format": "currency"
        },
        {
          "fieldId": "advance_sanctioned",
          "label": "Advance Sanctioned",
          "type": "number",
          "required": true,
          "placeholder": "Enter advance sanctioned amount",
          "format": "currency"
        },
        {
          "fieldId": "date_of_sanction",
          "label": "Date of Sanction",
          "type": "date",
          "required": true
        },
        {
          "fieldId": "advance_disallowed",
          "label": "Advance Subsequently Disallowed",
          "type": "radio",
          "required": true,
          "options": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "redFlagWhen": {
            "equals": "yes",
            "message": "Advance subsequently disallowed — requires investigation"
          }
        },
        {
          "fieldId": "mode_of_payment",
          "label": "Mode of Payment",
          "type": "dropdown",
          "required": true,
          "options": [
            {
              "label": "Cheque",
              "value": "cheque"
            },
            {
              "label": "NEFT/RTGS",
              "value": "neft_rtgs"
            },
            {
              "label": "Cash",
              "value": "cash"
            },
            {
              "label": "Other",
              "value": "other"
            }
          ]
        },
        {
          "fieldId": "date_of_payment",
          "label": "Date of Payment",
          "type": "date",
          "required": true
        },
        {
          "fieldId": "no_of_instalments",
          "label": "No. of Instalments for Recovery",
          "type": "number",
          "required": true,
          "placeholder": "Enter number of instalments"
        },
        {
          "fieldId": "amount_of_instalment",
          "label": "Amount of Instalment",
          "type": "number",
          "required": true,
          "placeholder": "Enter instalment amount",
          "format": "currency"
        }
      ]
    },
    {
      "sectionId": "outstanding_advance_table",
      "title": "Total O/S Advance Against Employee as on Date",
      "order": 4,
      "type": "table",
      "minRows": 1,
      "maxRows": 50,
      "allowAddRow": true,
      "columns": [
        {
          "columnId": "oa_date",
          "header": "Date",
          "type": "date",
          "width": "15%"
        },
        {
          "columnId": "oa_purpose",
          "header": "Purpose",
          "type": "text",
          "width": "30%"
        },
        {
          "columnId": "oa_total_advance",
          "header": "Total Advance",
          "type": "number",
          "format": "currency",
          "width": "18%"
        },
        {
          "columnId": "oa_repayment",
          "header": "Repayment",
          "type": "number",
          "format": "currency",
          "width": "18%"
        },
        {
          "columnId": "oa_outstanding",
          "header": "O/S as on Date",
          "type": "number",
          "format": "currency",
          "width": "19%",
          "computed": true,
          "formula": {
            "operation": "subtract",
            "operands": [
              {
                "columnId": "oa_total_advance"
              },
              {
                "columnId": "oa_repayment"
              }
            ]
          }
        }
      ]
    },
